<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoApplicationGroup.SignUpPage">
    <ContentPage.Content>
        <ScrollView>
            <VerticalStackLayout Padding="25" Spacing="10"
                                 VerticalOptions="Center">
                
                <Label 
                    x:Name="AppName"
                    Text="KittyDo"
                    FontSize="42"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    TextColor="{StaticResource SignInButtonColor}"
                    Margin="0,0,0,2"
                    CharacterSpacing="1.2"
                    LineHeight="1.0"
                />
            
                <Label 
                    x:Name="SignUpText"
                    Text="Sign Up"
                    FontSize="18"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    TextColor="{StaticResource SignUpButtonColor}"
                    Margin="0,0,0,14"
                    CharacterSpacing="0.3"
                />
                
                <Image
                    Source="hellokittynobg.png"
                    HeightRequest="185"
                    Aspect="AspectFit"
                    SemanticProperties.Description="hello kitty image" />
                
                <Entry
                    x:Name="UserNameEntry"
                    Placeholder="User name"
                    />
            
                <Entry
                    x:Name="EmailEntry"
                    Placeholder="Email address"
                    Keyboard="Email"
                />
            
                <Entry
                    x:Name="PasswordEntry"
                    Placeholder="Password"
                    IsPassword="True"
                />
                
                <Entry
                    x:Name="ConfirmPasswordEntry"
                    Placeholder="Confirm Password"
                    IsPassword="True"
                />
            
                <Button 
                    x:Name="SignUpBtn"
                    Text="Sign Up"
                    BackgroundColor="{StaticResource SignInButtonColor}"
                    TextColor="White"
                    Clicked="SignUpBtn_OnClicked"
                />
            
                <Button
                    x:Name="SignInBtn"
                    Text="Sign In"
                    BackgroundColor="{StaticResource SignUpButtonColor}"
                    TextColor="White"
                    Clicked="SignInBtn_OnClicked"
                />
            </VerticalStackLayout>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>