<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoApplicationGroup.ProfilePage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#EE6983">
    
    
    
    <Grid RowDefinitions="*, Auto">

        <!-- MAIN SCROLLABLE CONTENT -->
        <ScrollView Grid.Row="0" BackgroundColor="#FCF5EE">
            <VerticalStackLayout Spacing="0" Padding="0,0,0,20">

                <!-- Header Banner -->
                <Frame BackgroundColor="#EE6983"
                       CornerRadius="0"
                       HasShadow="False"
                       Padding="0"
                       HeightRequest="180">
                    <Grid>
                       
                        <VerticalStackLayout HorizontalOptions="Center"
                                             VerticalOptions="Center"
                                             Spacing="4">
                            <Label Text="✿ My Profile ✿"
                                   FontSize="26"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"/>
                            <Label Text=""
                                   FontSize="13"
                                   TextColor="#FCF5EE"
                                   Opacity="0.85"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

                <!-- Avatar Card -->
                <Frame Margin="30,-45,30,0"
                       CornerRadius="24"
                       BackgroundColor="White"
                       HasShadow="True"
                       Padding="24">
                    <VerticalStackLayout Spacing="16" HorizontalOptions="Center">

                        <!-- Profile Image Placeholder -->
                        <Frame WidthRequest="110"
                               HeightRequest="110"
                               CornerRadius="55"
                               BackgroundColor="#FFC4C4"
                               HasShadow="True"
                               Padding="0"
                               HorizontalOptions="Center">
                            <Grid>
                                <Image Source="avatar_img.jpg"
                                       WidthRequest="150"
                                       HeightRequest="150"
                                       Aspect="AspectFill"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Frame>

                        <!-- Name — x:Name kept from original -->
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label x:Name="UserNameLabel"
                                   Text=""
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="#850E35"
                                   HorizontalOptions="Center"/>
                            <Label Text="✦ Star Member ✦"
                                   FontSize="13"
                                   TextColor="#EE6983"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <!-- Divider -->
                        <BoxView HeightRequest="1"
                                 Color="#FFC4C4"
                                 Margin="0,4"/>

                        <!-- Stats row -->
                        <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="0">
                            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                                <Label Text="12"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="#850E35"
                                       HorizontalOptions="Center"/>
                                <Label Text="To-Dos"
                                       FontSize="11"
                                       TextColor="#EE6983"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            <BoxView Grid.Column="1"
                                     WidthRequest="1"
                                     Color="#FFC4C4"
                                     Margin="0,4"/>
                            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                                <Label Text="8"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="#850E35"
                                       HorizontalOptions="Center"/>
                                <Label Text="Done"
                                       FontSize="11"
                                       TextColor="#EE6983"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Grid>

                    </VerticalStackLayout>
                </Frame>

                <!-- Info Card -->
                <Frame Margin="30,20,30,0"
                       CornerRadius="20"
                       BackgroundColor="White"
                       HasShadow="True"
                       Padding="20">
                    <VerticalStackLayout Spacing="14">

                        <Label Text="♡ Account Info"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#850E35"/>

                        <!-- Email row — x:Name kept from original -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Frame Grid.Column="0"
                                   BackgroundColor="#FFC4C4"
                                   CornerRadius="10"
                                   Padding="8"
                                   HasShadow="False">
                                <Label Text="✉"
                                       FontSize="16"
                                       TextColor="#850E35"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Frame>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                <Label Text="Email"
                                       FontSize="11"
                                       TextColor="#EE6983"/>
                                <Label x:Name="EmailLabel"
                                       Text=""
                                       FontSize="14"
                                       TextColor="#850E35"
                                       FontAttributes="Bold"/>
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#FCF5EE"/>

                        <!-- Member since row -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Frame Grid.Column="0"
                                   BackgroundColor="#FFC4C4"
                                   CornerRadius="10"
                                   Padding="8"
                                   HasShadow="False">
                                <Label Text="🎀"
                                       FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Frame>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                <Label Text="Member Since"
                                       FontSize="11"
                                       TextColor="#EE6983"/>
                                <Label Text="January 2025"
                                       FontSize="14"
                                       TextColor="#850E35"
                                       FontAttributes="Bold"/>
                            </VerticalStackLayout>
                        </Grid>

                    </VerticalStackLayout>
                </Frame>

                <!-- Sign Out Button — Clicked kept from original -->
                <Frame Margin="30,24,30,0"
                       CornerRadius="18"
                       BackgroundColor="#EE6983"
                       HasShadow="True"
                       Padding="0">
                    <Button x:Name="SignOutBtn"
                            Text="✿  Sign Out  ✿"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="White"
                            BackgroundColor="Transparent"
                            HeightRequest="54"
                            Clicked="SignOutBtn_OnClicked"/>
                </Frame>

                <Label Text="♡♡♡"
                       FontSize="12"
                       TextColor="#EE6983"
                       Opacity="0.6"
                       HorizontalOptions="Center"
                       Margin="0,20,0,0"/>

            </VerticalStackLayout>
        </ScrollView>

        

    </Grid>
</ContentPage>
