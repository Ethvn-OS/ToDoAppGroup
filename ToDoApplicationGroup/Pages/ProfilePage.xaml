<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoApplicationGroup.ProfilePage"
             NavigationPage.HasNavigationBar="False">
    <ContentPage.Content>
        <VerticalStackLayout>
            <Label 
                Text="Profile Page"
                />
            
            <Label 
                x:Name="UserNameLabel"
                />
            
            <Label 
                x:Name="EmailLabel"
                />
            
            <Button 
                x:Name="SignOutBtn"
                Text="Sign Out"
                BackgroundColor="{StaticResource SignInButtonColor}"
                TextColor="White"
                Clicked="SignOutBtn_OnClicked"
                />
        </VerticalStackLayout>
    </ContentPage.Content>
</ContentPage>