<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ToDoApplicationGroup.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:ToDoApplicationGroup"
    Title="ToDoApplicationGroup">
    <TabBar>
        <ShellContent
            Title="ToDo"
            ContentTemplate="{DataTemplate local:ToDoMain}"
            Route="ToDoMain" />
        <ShellContent 
            Title="Completed"
            ContentTemplate="{DataTemplate local:CompletedPage}"
            Route="CompletedPage" />
        <ShellContent 
            Title="Profile"
            ContentTemplate="{DataTemplate local:ProfilePage}"
            Route="ProfilePage" />
    </TabBar>
</Shell>